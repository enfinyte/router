# =============================================================================
# api_platform
# =============================================================================

# Required — PostgreSQL connection string for the LLM router API
API_PLATFORM_PG_URL=postgres://user:password@localhost:5432/router

# Optional (default: 8080) — HTTP server port
API_PLATFORM_PORT=8080

# Optional (default: INFO) — Log level (DEBUG, INFO, WARN, ERROR)
API_PLATFORM_LOG_LEVEL=INFO

# Optional (default: http://localhost:8000) — Backend service URL for API key verification
API_PLATFORM_BACKEND_URL=http://localhost:8000

# =============================================================================
# backend
# =============================================================================

# Optional (default: 8000) — HTTP server port
BACKEND_PORT=8000

# Optional (default: http://localhost:3000) — Allowed CORS origin
BACKEND_CORS_ORIGIN=http://localhost:3000

# Optional (default: http://localhost:8000) — better-auth base URL
BACKEND_AUTH_BASE_URL=http://localhost:8000

# Required — PostgreSQL connection string for auth and secrets
BACKEND_PG_URL=postgres://user:password@localhost:5432/enfinyte_backend

# Required — GitHub OAuth app client ID
BACKEND_GITHUB_CLIENT_ID=your-github-oauth-client-id

# Required — GitHub OAuth app client secret
BACKEND_GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# =============================================================================
# vault
# =============================================================================

# Optional (default: http://127.0.0.1:8200) — Vault server URL
VAULT_ADDR=http://127.0.0.1:8200

# Required — Vault access token
VAULT_TOKEN=your-vault-root-token

# Conditional — Vault unseal key (only needed when Vault is sealed)
VAULT_TOKEN_KEY=your-vault-unseal-key

# Optional (default: Info) — Vault log level
VAULT_LOG_LEVEL=Info

# Optional (default: vault.log) — Vault log file path
VAULT_LOG_FILE=vault.log

# =============================================================================
# resolver
# =============================================================================

# Optional (default: Info) — Resolver log level
RESOLVER_LOG_LEVEL=Info

# Optional (default: resolver.log) — Resolver log file path
RESOLVER_LOG_FILE=resolver.log

# =============================================================================
# ledger
# =============================================================================

# Required — PostgreSQL connection string for analytics (TimescaleDB)
LEDGER_PG_URL=postgres://user:password@localhost:5432/enfinyte_ledger

# =============================================================================
# shared / library-mandated
# =============================================================================

# Required — Redis connection string (shared across services)
REDIS_URL=redis://localhost:6379

# Required — better-auth signing secret (library-mandated name)
BETTER_AUTH_SECRET=your-better-auth-signing-secret-min-32-chars

# Required — Database URL for migrations (library-mandated name, used by dbmate)
DATABASE_URL=postgres://user:password@localhost:5432/enfinyte_ledger?sslmode=disable

# Optional — AWS access key ID (library-mandated name, only needed for auto resolver mode)
AWS_ACCESS_KEY_ID=your-aws-access-key-id

# Optional — AWS secret access key (library-mandated name, only needed for auto resolver mode)
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Optional — AWS region (library-mandated name, only needed for auto resolver mode)
AWS_REGION=us-east-1
